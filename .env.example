# Supabase Configuration
# Для локальной разработки используйте эти значения после запуска `supabase start`

# Локальные значения (после запуска supabase start)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Для продакшена замените на ваши реальные значения из Supabase Dashboard
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-production-anon-key
